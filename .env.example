PORT=8080

DATABASE_URL=postgres://auth:auth_secret@localhost:5432/auth_db?sslmode=disable
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-to-a-random-32-char-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

OAUTH_REDIRECT_BASE=http://localhost:8080

# Google — console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft — portal.azure.com
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Facebook — developers.facebook.com
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Apple — developer.apple.com
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=   # base64-encoded .p8 file contents
